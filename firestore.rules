rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "deepanshthakur866@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email']) &&
             data.uid is string &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 50 &&
             data.email is string;
    }

    function isValidTestResult(data) {
      return data.keys().hasAll(['userId', 'wpm', 'accuracy', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.wpm is number && data.wpm >= 0 &&
             data.accuracy is number && data.accuracy >= 0 && data.accuracy <= 100;
    }

    function isValidLeaderboardEntry(data) {
      return data.keys().hasAll(['uid', 'displayName', 'bestWpm', 'bestAccuracy']) &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 50 &&
             data.bestWpm is number && data.bestWpm >= 0 &&
             data.bestAccuracy is number && data.bestAccuracy >= 0 && data.bestAccuracy <= 100;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    match /leaderboard/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId) && isValidLeaderboardEntry(request.resource.data);
      allow delete: if isAdmin();
    }

    match /testResults/{resultId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidTestResult(request.resource.data);
      allow update: if (isAuthenticated() && resource.data.userId == request.auth.uid && isValidTestResult(request.resource.data)) || isAdmin();
      allow delete: if isAdmin();
    }
  }
}
