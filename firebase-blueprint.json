{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and statistics",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "bestWpm": { "type": "number" },
        "bestAccuracy": { "type": "number" },
        "averageWpm": { "type": "number" },
        "totalTests": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email"]
    },
    "TestResult": {
      "title": "Test Result",
      "description": "Individual typing test performance",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "wpm": { "type": "number" },
        "accuracy": { "type": "number" },
        "correctChars": { "type": "number" },
        "incorrectChars": { "type": "number" },
        "totalChars": { "type": "number" },
        "duration": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "wpm", "accuracy", "timestamp"]
    },
    "LeaderboardEntry": {
      "title": "Leaderboard Entry",
      "description": "Public leaderboard entry for a user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "bestWpm": { "type": "number" },
        "bestAccuracy": { "type": "number" },
        "totalTests": { "type": "number" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "bestWpm", "bestAccuracy"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/testResults/{resultId}": {
      "schema": "TestResult",
      "description": "Typing test results for leaderboard and history"
    },
    "/leaderboard/{userId}": {
      "schema": "LeaderboardEntry",
      "description": "Public leaderboard entries"
    }
  }
}
